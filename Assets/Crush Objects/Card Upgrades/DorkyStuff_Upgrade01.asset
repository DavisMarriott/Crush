        lastSticks: 0
      - character: 0
        confidenceImpact: 0
        charmImpact: 0
        line: Good point.
        variantGroups: []
        lastSticks: 0
      - character: 1
        confidenceImpact: 3
        charmImpact: 0
        line: "I\u2019m going to wear it like a badge of honor! Hehe."
        variantGroups: []
        lastSticks: 0
      - character: 1
        confidenceImpact: 0
        charmImpact: 0
        line: "But I won\u2019t tell anyone you\u2019re a dork."
        variantGroups: []
        lastSticks: 0
