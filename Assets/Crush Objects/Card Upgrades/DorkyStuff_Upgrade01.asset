        lastSticks: 0
      - character: 2
        confidenceImpact: 0
        charmImpact: 0
        line: Like GLUE!
        variantGroups: []
        lastSticks: 0
      - character: 1
        confidenceImpact: 4
        charmImpact: 0
        line: "I wanna hear more about the stuff you\u2019re into some time."
