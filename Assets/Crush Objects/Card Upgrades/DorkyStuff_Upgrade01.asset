    - charmState: 2
      dialogue:
      - character: 1
        confidenceImpact: 1
        charmImpact: 0
        line: Thanks, I think. We like what we like, right?
        variantGroups: []
        lastSticks: 0
      - character: 1
        confidenceImpact: 1
        charmImpact: 0
        line: "What\u2019s even considered \u201Cdorky\u201D anymore, anyway?"
