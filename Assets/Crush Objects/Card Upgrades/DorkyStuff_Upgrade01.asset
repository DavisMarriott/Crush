      - character: 1
        confidenceImpact: 0
        charmImpact: 0
        line: "Hehe, I know. That\u2019s sweet."
        variantGroups: []
        lastSticks: 0
      - character: 1
        confidenceImpact: 2
        charmImpact: 0
        line: Dorks like us gotta stick together, Luke.
