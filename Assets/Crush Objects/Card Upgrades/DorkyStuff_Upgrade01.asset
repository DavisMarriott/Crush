        lastSticks: 0
      - character: 1
        confidenceImpact: 0
        charmImpact: 0
        line: "I\u2019m teasing!"
        variantGroups: []
        lastSticks: 0
      - character: 2
        confidenceImpact: 0
        charmImpact: 0
        line: Phew! Thank GOD!
        variantGroups: []
        lastSticks: 0
      - character: 0
        confidenceImpact: 0
        charmImpact: 0
